# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Gmail address the scraper sends FROM (and logs in with)
GMAIL_SENDER=easttxkravmaga@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App Passwords" → create one for Mail
#   4. Paste the 16-character code below (no spaces)
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Who receives the CSV
RECIPIENT_EMAIL=easttxkravmaga@gmail.com
