# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-in-production

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=etkm_imagegen

# ── Image Generation ─────────────────────────────────────
# Option A: Manus Forge (built-in)
FORGE_API_URL=
FORGE_API_KEY=

# Option B: Google Imagen 3 (fallback)
GEMINI_API_KEY=

# ── AWS S3 ────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=etkm-imagegen

# ── Manus OAuth ──────────────────────────────────────────
MANUS_API_URL=https://api.manus.im
MANUS_CLIENT_ID=
MANUS_CLIENT_SECRET=
APP_URL=http://localhost:3000
